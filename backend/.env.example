# Copia este archivo a .env y completa los valores reales
# cp .env.example .env

# Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_anon_key_de_supabase

# Servidor
PORT=3000

# Telegram bot (opcional; necesario solo para alertas)
TELEGRAM_BOT_TOKEN=123456:tu_token_de_botfather
# Cualquier string secreto que tu defines. Se valida en el webhook.
TELEGRAM_WEBHOOK_SECRET=algo-aleatorio-y-largo
